<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Career Admin Panel</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<script src="/socket.io/socket.io.js"></script>

<style>

/* ===== GLOBAL ===== */
body {
  margin: 0;
  font-family: 'Poppins', sans-serif;
  background: #020617;
  color: #e2e8f0;
  opacity: 0;
  transition: opacity 0.5s ease;
}

body.loaded {
  opacity: 1;
}

/* ===== SIDEBAR ===== */
.sidebar {
  width: 240px;
  height: 100vh;
  position: fixed;
  background: linear-gradient(180deg,#020617,#0f172a);
  padding: 20px;
  transition: 0.4s;
}

.sidebar.closed {
  width: 80px;
}

.sidebar h4 {
  color: #fff;
  text-align: center;
  margin-bottom: 30px;
}

.sidebar a {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border-radius: 12px;
  color: #cbd5e1;
  text-decoration: none;
  margin-bottom: 10px;
  transition: 0.3s;
}

.sidebar a i {
  font-size: 18px;
}

.sidebar.closed a span {
  display: none;
}

.sidebar a:hover,
.sidebar a.active {
  background: #1e293b;
  color: #fff;
}

/* ===== MAIN ===== */
.main {
  margin-left: 240px;
  padding: 25px;
  transition: 0.4s;
}

.main.full {
  margin-left: 80px;
}

/* ===== TOPBAR ===== */
.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* ===== CARD ===== */
.card {
  background: rgba(30,41,59,0.6);
  backdrop-filter: blur(12px);
  border-radius: 20px;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 10px 40px rgba(0,0,0,0.6);
  transition: 0.3s;
}

.card:hover {
  transform: translateY(-5px);
}

/* ===== STATS ===== */
.stat h2 {
  font-size: 32px;
  font-weight: bold;
}

.total { color: #38bdf8; }
.pending { color: #f59e0b; }
.completed { color: #22c55e; }

/* ===== TABLE ===== */
.table {
  color: #e2e8f0;
  border-radius: 12px;
  overflow: hidden;
}

.table thead {
  background: rgba(255,255,255,0.08);
}

.table-hover tbody tr:hover {
  background: rgba(255,255,255,0.06);
  transition: 0.3s;
}

/* ===== BADGES ===== */
.badge-pending {
  background: rgba(245,158,11,0.2);
  color: #f59e0b;
  padding: 6px 14px;
  border-radius: 20px;
}

.badge-completed {
  background: rgba(34,197,94,0.2);
  color: #22c55e;
  padding: 6px 14px;
  border-radius: 20px;
}

/* ===== BUTTONS ===== */
.btn-action {
  border-radius: 50%;
}

.btn-success {
  background: linear-gradient(135deg,#22c55e,#16a34a);
  border: none;
}

.btn-danger {
  background: linear-gradient(135deg,#ef4444,#dc2626);
  border: none;
}

.btn-info {
  background: linear-gradient(135deg,#06b6d4,#0891b2);
  border: none;
}

/* ===== LOGOUT ===== */
.logout-btn {
  background: linear-gradient(135deg,#ef4444,#b91c1c);
  border-radius: 25px;
  padding: 10px;
  text-align: center;
  margin-top: 20px;
}

/* ===== NOTIFICATION ===== */
.notif-box {
  position: fixed;
  right: 20px;
  top: 70px;
  background: #1e293b;
  padding: 15px;
  border-radius: 12px;
  width: 260px;
  display: none;
  z-index: 999;
}

</style>
</head>

<body>

<!-- SIDEBAR -->
<div id="sidebar" class="sidebar">
  <h4>🚀</h4>

  <a href="/api/admin">
    <i class="bi bi-envelope"></i> <span class="fw-bold">Contact</span>
  </a>

  <a href="/api/admin/careers" class="active">
    <i class="bi bi-briefcase"></i> <span class="fw-bold">Careers</span>
  </a>

  <a href="/api/logout" class="logout-btn">
    <i class="bi bi-box-arrow-right"></i> <span class="fw-bold">Logout</span>
  </a>
</div>

<!-- MAIN -->
<div id="main" class="main">

<div class="topbar mb-4">
  <div class="d-flex align-items-center gap-3">
    <button class="btn btn-dark" onclick="toggleSidebar()">☰</button>
    <h4 class="fw-bold">💼 Career Dashboard</h4>
  </div>

  <button class="btn btn-dark" onclick="toggleNotif()">
    🔔 <span id="count">0</span>
  </button>
</div>

<div id="notif" class="notif-box"></div>

<!-- STATS -->
<div class="row g-3 mb-4">

  <div class="col-md-4">
    <div class="card text-center p-4 stat">
      <small class="text-light fw-bold">Total</small>
      <h2 class="total"><%= data.length %></h2>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card text-center p-4 stat">
      <small class="text-light fw-bold">Pending</small>
      <h2 class="pending"><%= data.filter(d=>d.status==='pending').length %></h2>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card text-center p-4 stat">
      <small class="text-light fw-bold">Completed</small>
      <h2 class="completed"><%= data.filter(d=>d.status==='completed').length %></h2>
    </div>
  </div>

</div>

<!-- TABLE -->
<div class="card p-3">
<div class="table-responsive">

<table class="table table-hover align-middle text-center">
<thead>
<tr>
  <th>#</th>
  <th>Name</th>
  <th>Email</th>
  <th>Role</th>
  <th>Resume</th>
  <th>Status</th>
  <th>Action</th>
</tr>
</thead>

<tbody>

<% data.forEach((item,index)=>{ %>
<tr>
<td><%= index+1 %></td>
<td><strong><%= item.name %></strong></td>
<td class="text-muted"><%= item.email %></td>
<td><%= item.role %></td>

<td>
  <% if(item.resume){ %>
    <button class="btn btn-info btn-sm" onclick="previewResume('<%= item.resume %>')">
      <i class="bi bi-eye"></i>
    </button>

    <a href="/uploads/<%= item.resume %>" class="btn btn-info btn-sm" download>
      <i class="bi bi-download"></i>
    </a>
  <% } %>
</td>

<td>
  <select class="form-select mb-1"
    onchange="handleStatusChange(<%= item.id %>, this.value)">

    <option value="pending" <%= item.status==='pending'?'selected':'' %>>Pending</option>
    <option value="shortlisted" <%= item.status==='shortlisted'?'selected':'' %>>Shortlisted</option>
    <option value="completed" <%= item.status==='completed'?'selected':'' %>>Interview</option>
    <option value="rejected" <%= item.status==='rejected'?'selected':'' %>>Rejected</option>

  </select>

  <!-- 📅 DATE PICKER -->
  <input type="date" id="date-<%= item.id %>" class="form-control"
    value="<%= item.interview_date ? item.interview_date.toISOString().split('T')[0] : '' %>">
</td>

<td>
  <% if(item.status==='pending'){ %>
    <a href="/api/career/complete/<%= item.id %>" class="btn btn-success btn-sm btn-action">
      <i class="bi bi-check"></i>
    </a>
  <% } %>

  <a href="/api/career/delete/<%= item.id %>" class="btn btn-danger btn-sm btn-action">
    <i class="bi bi-trash"></i>
  </a>
</td>
</tr>
<% }) %>

</tbody>
</table>

</div>
</div>

</div>

<!-- MODAL -->
<div class="modal fade" id="resumeModal">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-body">
        <iframe id="resumeFrame" width="100%" height="500px"></iframe>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>

/* PAGE LOAD ANIMATION */
window.onload = () => {
  document.body.classList.add("loaded");
};

/* SIDEBAR */
function toggleSidebar(){
  document.getElementById("sidebar").classList.toggle("closed");
  document.getElementById("main").classList.toggle("full");
}

/* RESUME */
function previewResume(file){
  document.getElementById("resumeFrame").src = "/uploads/" + file;
  new bootstrap.Modal(document.getElementById("resumeModal")).show();
}

/* NOTIFICATION FIX */
let count = 0;
const socket = io();

socket.on("newCareer",(data)=>{
  count++;
  document.getElementById("count").innerText = count;

  const box = document.getElementById("notif");
  box.style.display = "block";

  box.innerHTML = `
    <b>${data.name}</b><br>
    <small>${data.email}</small>
  `;
});

/* TOGGLE FIX */
function toggleNotif(){
  const box = document.getElementById("notif");

  if(box.style.display === "block"){
    box.style.display = "none";
  } else {
    box.style.display = "block";
  }
}



</script>
<script>
function handleStatusChange(id, status) {

  let interviewDate = null;

  if (status === "completed") {
    interviewDate = document.getElementById("date-" + id).value;

    if (!interviewDate) {
      alert("Please select interview date 📅");
      return;
    }
  }

  fetch("/api/career/status", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ id, status, interviewDate })
  })
  .then(res => res.json())
  .then(() => {
    alert("Updated ✅");
  });
}
</script>

<script>
socket.on("statusUpdated", () => {
  location.reload(); // 🔥 AUTO REFRESH TABLE
});

socket.on("newCareer", () => {
  location.reload(); // 🔥 NEW ENTRY AUTO SHOW
});
</script>

</body>
</html>