<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Admin Dashboard</title>
  <script src="/socket.io/socket.io.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<style>
body {
  font-family: 'Poppins', sans-serif;
  background: #0f172a;
  color: #fff;
}
/* DARK MODE TEXT FIX */
body:not(.light-mode) .text-muted {
  color: #cbd5e1 !important; /* light gray */
}

body:not(.light-mode) h5 {
  color: #ffffff;
}
/* HEADER */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

/* CARD */
.card {
  background: linear-gradient(145deg, #1e293b, #0f172a);
  border-radius: 18px;
  box-shadow: 0 8px 30px rgba(0,0,0,0.6);
  border: none;
}

/* STAT CARDS */
.stat-card {
  text-align: center;
  padding: 20px;
}
.stat-card h3 {
  font-size: 28px;
}



/* TABLE */
.table {
  border-radius: 10px;
  overflow: hidden;
}

/* BADGES */
.badge-pending {
  background: orange;
  padding: 6px 12px;
  border-radius: 20px;
}
.badge-completed {
  background: #22c55e;
  padding: 6px 12px;
  border-radius: 20px;
}

/* BUTTON */
.btn-action {
  border-radius: 20px;
  padding: 5px 10px;
}

/* SEARCH */
.search-box input {
  border-radius: 20px;
}

/* NOTIFICATION */
.toast-container {
  position: fixed;
  top: 20px;
  right: 20px;
  z-index: 999;
}

/* LIGHT MODE */
.light-mode {
  background: #f1f5f9;
  color: #111;
}
.light-mode .card {
  background: #ffffff;
  color: #111;
}

.light-mode .table {
  background: #fff;
  color: #111;
}

.light-mode .table thead {
  background: #e2e8f0;
}

.light-mode .badge-pending {
  background: #f59e0b;
}

.light-mode .badge-completed {
  background: #16a34a;
}
.light-mode .card,.stat-card,
.light-mode #notifBox,
.light-mode .toast {
  background: #ffffff !important;
  color: #111 !important;
}

.light-mode #notifBox strong,
.light-mode #notifBox small {
  color: #111 !important;
}

.light-mode .text-muted {
  color: #555 !important;
}

.notif-item {
  border-radius: 8px;
}

.light-mode .notif-item {
  background: #f8fafc;
}

#clearBtn i {
  color: #94a3b8;
  transition: 0.2s;
}

#clearBtn i:hover {
  color: #ef4444;
  transform: scale(1.2);
}

.card {
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,0.1);
}

.card:hover {
  transform: translateY(-5px);
  transition: 0.3s;
}
body:not(.light-mode) h5,
body:not(.light-mode) small {
  color: #e2e8f0 !important;
}
.table-hover tbody tr:hover {
  background: rgba(255,255,255,0.05);
}

#notifBox {
  border-radius: 15px;
  backdrop-filter: blur(15px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}
</style>

<script>
let notifCount = 0;

/* 🌙 THEME TOGGLE */
function toggleTheme() {
  document.body.classList.toggle("light-mode");

  const btn = document.getElementById("themeBtn");

  if (document.body.classList.contains("light-mode")) {
    btn.innerText = "☀️ Light";
    localStorage.setItem("theme", "light");
  } else {
    btn.innerText = "🌙 Dark";
    localStorage.setItem("theme", "dark");
  }
}

/* 🔄 LOAD THEME */
window.onload = () => {
  const theme = localStorage.getItem("theme");
  const btn = document.getElementById("themeBtn");

  if (theme === "light") {
    document.body.classList.add("light-mode");
    btn.innerText = "☀️ Light";
  } else {
    btn.innerText = "🌙 Dark";
  }
};

/* 🔔 NOTIFICATION TOGGLE */
function toggleNotif(){
  document.getElementById("notifBox").classList.toggle("d-none");
}

/* 🔥 SOCKET (REAL TIME FIXED) */
const socket = io();

socket.on("newContact", (data) => {

  notifCount++;
  document.getElementById("notifCount").innerText = notifCount;

  // add notification item
  const notifList = document.getElementById("notifList");

  notifList.innerHTML = `
  <div class="mb-2 p-2 border-bottom notif-item">
    <strong>${data.fname} ${data.lname}</strong><br>
    <small class="text-muted">${data.email}</small>
  </div>
` + notifList.innerHTML;

  // add table row
 const row = `
  <tr>
    <td>${data.id}</td>
    <td>${data.fname} ${data.lname}</td>
    <td>${data.email}</td>
    <td>${data.services}</td>

    <!-- ✅ MESSAGE -->
    <td>${data.msg || ''}</td>

    <td><span class="badge-pending">Pending</span></td>
    <td>
      <a href="/api/complete/${data.id}" class="btn btn-success btn-sm">✔</a>
      <a href="/api/delete/${data.id}" class="btn btn-danger btn-sm">🗑</a>
    </td>
  </tr>
`;

  document.getElementById("tableData")
    .insertAdjacentHTML("afterbegin", row);
});
</script>


</head>
<script>let totalVisitors = 0;
</script>
<body>

<div class="container py-4">

<!-- HEADER -->
<div class="header">
  <h4>🚀 MotionPix Admin</h4>
  <div class="mb-3">
  <a href="/api/admin" class="btn btn-primary">📩 Contact</a>
  <a href="/api/admin/careers" class="btn btn-warning">💼 Careers</a>
</div>

  <div class="d-flex gap-2">
      <button id="themeBtn" onclick="toggleTheme()" class="btn btn-dark">
        🌙 Dark Mode
      </button>
  <div class="position-relative">

  <button class="btn btn-dark" onclick="toggleNotif()">
    🔔 <span id="notifCount" class="badge bg-danger">0</span>
  </button>
<div id="notifBox"
     class="card p-2 d-none"
     style="width:300px; position:absolute; right:0; top:45px; z-index:999; background:inherit;">

    <strong>Notifications</strong>
    <hr>

    <div id="notifList">
      <p class="text-muted mb-0">No notifications</p>
    </div>

  </div>
</div>
    <a href="/api/logout" class="btn btn-danger d-flex align-items-center gap-2"  onclick="return confirmLogout()">
      Logout <i class="bi bi-box-arrow-right"></i> 
    </a>
</div>
</div>


<!-- 🔥 PRO KPI + ANALYTICS -->
<div class="row g-3 mb-4">

  <!-- TOTAL -->
  <div class="col-md-4">
    <div class="card p-4 stat-card" style="background: linear-gradient(135deg,#1e293b,#0b1220); border-left:4px solid #3b82f6;">
      <small class="text-muted">Total Inquiries</small>
      <h2 class="mb-0"><%= data.length %></h2>
    </div>
  </div>

  <!-- PENDING -->
  <div class="col-md-4">
    <div class="card p-4 stat-card" style="background: linear-gradient(135deg,#1e293b,#0b1220); border-left:4px solid orange;">
      <small class="text-muted">Pending</small>
      <h2 class="mb-0" style="color:orange;"><%= data.filter(d=>d.status==='pending').length %></h2>
    </div>
  </div>

  <!-- COMPLETED -->
  <div class="col-md-4">
    <div class="card p-4 stat-card" style="background: linear-gradient(135deg,#1e293b,#0b1220); border-left:4px solid #22c55e;">
      <small class="text-muted">Completed</small>
      <h2 class="mb-0" style="color:#22c55e;"><%= data.filter(d=>d.status==='completed').length %></h2>
    </div>
  </div>

</div>


<!-- SEARCH -->
<form method="GET" action="/api/admin" class="mb-3 row g-2">
  <div class="col-md-4 position-relative">

    <!-- 🔍 INPUT -->
    <input type="text"
           id="searchInput"
           name="search"
           placeholder="Search by name/email..."
           value="<%= search %>"
           class="form-control pe-5 fw-bold">

    <!-- ❌ CLEAR BUTTON -->
    <span id="clearBtn"
          onclick="clearSearch()"
          style="position:absolute; right:15px; top:50%; transform:translateY(-50%); cursor:pointer; display:none;">
      <i class="bi bi-x-circle-fill"></i>
    </span>

  </div>

  <div class="col-md-3">
    <select name="status" class="form-control fw-bold">
      <option value="">All</option>
      <option value="pending" <%= status==='pending'?'selected':'' %>>Pending</option>
      <option value="completed" <%= status==='completed'?'selected':'' %>>Completed</option>
    </select>
  </div>

  <div class="col-md-2">
    <button class="btn btn-primary w-100 fw-bold">Search</button>
  </div>
</form>



<!-- 📊 ANALYTICS CARD -->
<div class="card p-4 mb-4">

  <div class="d-flex justify-content-between align-items-center mb-3">-
    <div>
      <h5 class="mb-0">📊 Analytics Overview</h5>
      <small class="text-muted">Real-time inquiry insights</small>
    </div>

    <span class="badge bg-primary px-3 py-2">Live</span>
  </div>

  <div style="background:#0b1220; padding:15px; border-radius:12px;">
    <canvas id="myChart" height="100"></canvas>
  </div>

</div>

<!-- TABLE -->
<div class="card p-3">
<div class="table-responsive">

<table class="table table-dark table-hover align-middle">
<thead>-
<tr>
  <th>#</th>
  <th>Name</th>
  <th>Email</th>
  <th>Service</th>
  <th>Message</th>
  <th>Contact</th>
  <th>Status</th>
  <th>Action</th>
</tr>
</thead>

<tbody id="tableData">
<% data.forEach((item,index)=>{ %>
<tr>
  <td class="fw-bold"><%= index+1 %></td>
  <td class="fw-bold"><%= item.fname %> <%= item.lname %></td>
  <td class="fw-bold"><%= item.email %></td>
  <td class="fw-bold"><%= item.services %></td>
  <td class="fw-bold" style=" 
  max-width: 200px;
  word-wrap: break-word;
  white-space: normal;
  word-break: break-word;
"><%= item.msg %></td>
  <td class="fw-bold"><%=item.contact%></td>

  <td class="fw-bold">
    <% if(item.status==='pending'){ %>
      <span class="badge-pending fw-bold">Pending</span>
    <% } else { %>
      <span class="badge-completed fw-bold">Completed</span>
    <% } %>
  </td>

  <td class="fw-bold">
    <% if(item.status==='pending'){ %>
      <a href="/api/complete/<%= item.id %>" class="btn btn-success btn-action">✔</a>
    <% } %>
    <a href="/api/delete/<%= item.id %>" class="btn btn-danger btn-action">🗑</a>
  </td>
</tr>
<% }) %>
</tbody>

</table>

</div>
</div>
<ul id="visitorList"></ul>
<div class="card p-3 mb-3">
  <h5>📊 Visitor Stats</h5>
  <p class="fw-bold text-light">Last Visit: <span id="lastVisitors">0</span></p>
  <p class="fw-bold text-light">Current: <span id="currentVisitors">0</span></p>
</div>

<div id="map" style="height:400px;"></div>

</div>

<!-- SCRIPT -->
<script>
/* CHART */
const chartData = <%- JSON.stringify(chartData || []) %>;

const labels = chartData.map(i => i.services);
const counts = chartData.map(i => i.count);

new Chart(document.getElementById('myChart'), {
  type: 'bar',
  data: {
    labels,
    datasets: [{
      label: 'Inquiries',
      data: counts,
      backgroundColor: 'rgba(59,130,246,0.7)',
      borderRadius: 10
    }]
  },
  options: {
    plugins: {
      legend: { display: false }
    },
    scales: {
      x: {
        grid: { display: false }
      },
      y: {
        grid: { color: "rgba(255,255,255,0.05)" }
      }
    }
  }
});

/* 📄 PAGINATION (CLIENT SIDE SIMPLE) */
const rows = document.querySelectorAll("#tableData tr");
const perPage = 5;
let currentPage = 1;

function showPage(page){
  rows.forEach((row,i)=>{
    row.style.display = (i >= (page-1)*perPage && i < page*perPage) ? "" : "none";
  });
}
showPage(1);


</script>

<script>
function confirmLogout(){
  return confirm("Are you sure you want to logout?");
}
</script>

<script>
const searchInput = document.getElementById("searchInput");
const clearBtn = document.getElementById("clearBtn");

// show/hide X button
function toggleClearBtn(){
  if(searchInput.value.length > 0){
    clearBtn.style.display = "block";
  } else {
    clearBtn.style.display = "none";
  }
}

// clear input
function clearSearch(){
  searchInput.value = "";
  clearBtn.style.display = "none";
  searchInput.focus();
}

// event
searchInput.addEventListener("input", toggleClearBtn);

// initial check (page reload case)
window.addEventListener("load", toggleClearBtn);
</script>
<script>
let map;
let markersLayer; // all visitor markers live here so they can be cleared/rebuilt cleanly

// =========================
// EXISTING VISITORS (BLUE) — always redrawn fresh from the DB, so a
// visitor removed/changed outside this open tab (e.g. a manual DB
// reset) can never leave a stale marker sitting on the map.
// =========================
async function renderAllVisitors() {
  markersLayer.clearLayers();

  const res = await fetch("/api/all-visitors");
  const visitors = await res.json();

  visitors.forEach(v => {
    if (!v.lat || !v.lon) return;

    L.circleMarker([v.lat, v.lon], {
      radius: 8,
      fillColor: "#00d4ff",
      color: "#00d4ff",
      fillOpacity: 0.8
    })
    .addTo(markersLayer)
    .bindPopup(`
      📍 Existing Visitor<br>
      ${v.city || "Unknown"}, ${v.country || ""}
    `);
  });
}

window.addEventListener("load", async () => {

  map = L.map("map").setView([20.5937, 78.9629], 5);

  L.tileLayer(
    "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png"
  ).addTo(map);

  markersLayer = L.layerGroup().addTo(map);

  await loadTotalVisitors();
  await renderAllVisitors();

  // =========================
  // LATEST VISITOR (RED)
  // =========================
  socket.on("visitorUpdate", async (data) => {
    // Rebuild the whole marker set from the DB first (clears any stale
    // marker), then highlight this visit on top of the fresh set.
    await renderAllVisitors();

    document.getElementById("currentVisitors").innerText = data.total;
    document.getElementById("lastVisitors").innerText = data.total;

    if (!data.lat || !data.lon) return;

    L.circleMarker([data.lat, data.lon], {
      radius: 11,
      fillColor: "#ff3b3b",
      color: "#ff3b3b",
      fillOpacity: 0.95
    })
    .addTo(markersLayer)
    .bindPopup(`
      🔥 Latest Visitor<br>
      ${data.city || "Unknown"}, ${data.country || ""}<br>
      Total Visitors: ${data.total}
    `)
    .openPopup();
  });

});


// =========================
// LOAD VISITOR STATS
// =========================
async function loadTotalVisitors() {
  const res = await fetch("/api/track-visitor");
  const data = await res.json();

  document.getElementById("currentVisitors").innerText = data.total;
  document.getElementById("lastVisitors").innerText = data.last;
}
</script>
</body>
</html>
